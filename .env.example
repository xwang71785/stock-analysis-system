# API Credentials
TUSHARE_TOKEN=your_tushare_token_here
EASTMONEY_API_KEY=your_eastmoney_api_key_here

# Cache Configuration
CACHE_DIR=./cache

# API Configuration
CAIXIN_RATE_LIMIT=60  # seconds between requests

# Application Configuration
APP_NAME=Stock Analysis System
